# ---- Admin ----
# Password for /admin dashboard
ADMIN_PASSWORD=

# HMAC key for signing session cookies. Use at least 32 random chars.
SESSION_SECRET=

# Cookie name and lifetime for the admin session. Defaults: "iyf_session" / 12h.
SESSION_COOKIE_NAME=iyf_session
SESSION_TTL_SECONDS=43200

# ---- Email (Resend) ----
# https://resend.com/api-keys
RESEND_API_KEY=

# Must be a verified sender on Resend.
# Use onboarding@resend.dev to send only to the Resend account owner during sandbox.
MAIL_FROM=ISKCON Youth Forum <onboarding@resend.dev>

# Where admin notifications are delivered
ADMIN_EMAIL=

# ---- Persistence (Redis Cloud) ----
# Use the TCP `rediss://` (TLS) URL from your Redis Cloud dashboard.
# Credentials may be embedded in the URL (user:password@host).
# https://cloud.redis.io → your database → "Connect" → "Redis URL"
REDIS_URL=

# How long to keep form submissions in Redis (seconds). Default: 90 days.
SUBMISSION_TTL_SECONDS=7776000

# ---- Optional (public site) ----
PUBLIC_SITE_NAME=ISKCON Youth Forum, Sylhet
PUBLIC_SITE_URL=http://localhost:3000
